# Theta Quant — NON-SECRET config overrides. Copy to .env (gitignored).
# Secrets (Kite keys, passwords, tokens) do NOT go here — they live as runtime
# files under ~/.config on the host and are mounted into the container read-only.

# --- Filesystem (defaults reproduce the native Mac-mini layout) ---
# TQ_DATA_DIR=/data
# TQ_CONFIG_DIR=~/.config
# TQ_PARQUET_DIR=/data/parquet
# TQ_JOURNAL=/data/trade_journal.jsonl

# --- Networking ---
# Comma-separated hosts allowed through the reverse proxy / tunnel (SSRF guard).
# TG_TRUSTED_HOSTS=

# --- Cloud adapter (Phase 2, gated) — leave blank for the local standard build ---
# When empty/local, the app runs 100% locally with zero cloud dependencies.
# Name matches DEPLOYMENT.md §2b. Cloud SDKs live in requirements-cloud.txt only.
# STORAGE_BACKEND=local           # local | supabase   (default: local)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=      # server-side only; never expose to the browser
